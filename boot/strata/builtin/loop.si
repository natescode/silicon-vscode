@stratum_keyword Loop ('@loop', Node) = {
  &IR::control_loop;
  @local condN := &Compiler::arg Node, 0;
  @local bodyN := &Compiler::arg Node, 1;
  @local id    := &Compiler::ctx::nextLoopId;
  &Compiler::ctx::loopStack::push id;
  @local cond  := &Compiler::lowerExpr condN;
  @local body  := &Compiler::lowerExpr bodyN;
  &Compiler::ctx::loopStack::pop;
  &Compiler::ir::makeLoop id, cond, body;
};
